{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": [
      "node",
      "mocha",
      "@wdio/globals/types",
      "expect-webdriverio"
    ]
  },
  "include": [
    "test/**/*.ts",
    "wdio.conf.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
